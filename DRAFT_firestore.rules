rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // Validation helper for Post
    function isValidPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.content is string && data.content.size() <= 1000000 &&
             data.author is string && data.author.size() <= 100;
    }

    match /posts/{postId} {
      // Public read access for the blog
      allow get: if true;
      allow list: if true;

      // Restrict writes to authorized admin
      // In a real app, we'd check a specific UID or email
      allow create: if isSignedIn() && isValidPost(request.resource.data);
      allow update: if isSignedIn() && isValidPost(request.resource.data);
      allow delete: if isSignedIn();
    }
  }
}
